{
    "name": "honeyent-backend",
    "version": "1.0.0",
    "description": "Honeyent ERP Backend - PostgreSQL + Node.js",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "build:watch": "tsc --watch",
        "lint": "eslint src --ext .ts",
        "migrate": "tsx ./scripts/migrate.ts"
    },
    "keywords": [
        "erp",
        "logistics",
        "postgresql",
        "express"
    ],
    "author": "Sumit Singh",
    "license": "MIT",
    "dependencies": {
        "cors": "^2.8.6",
        "decimal.js": "^10.6.0",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.21.0",
        "zod": "^4.4.3",
        "bcryptjs": "^2.4.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^25.9.3",
        "@types/pg": "^8.20.0",
        "@types/bcryptjs": "^2.4.6",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "eslint": "^10.4.1",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    }
}